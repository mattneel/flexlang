module Main

type Point =
{
  x: I64
  y: I64
}

fn make(x: I64, y: I64) -> Point = { x = x, y = y }

fn getx(p: Point) -> I64 = { p.x }

fn moved(p: Point) -> Point = { p with x = 100 }

fn main() -> I64 =
{
  let p = make(40, 2)
  let q = moved(p)
  getx(p) + p.y + getx(q)
}

test "record fields and update" {
  let p = make(3, 4)
  assert_eq(p.x, 3)
  assert_eq(p.y, 4)
  let q = { p with y = 9 }
  assert_eq(q.x, 3)
  assert_eq(q.y, 9)
}
